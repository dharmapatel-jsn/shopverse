PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/shopverse

# App mode
NODE_ENV=development

# User auth JWT
JWT_SECRET=replace_with_a_strong_secret_min_32_chars
JWT_EXPIRE=7d

# Admin auth JWT
JWT_ADMIN_SECRET=replace_with_a_second_strong_secret_min_32_chars
JWT_ADMIN_EXPIRE=30d

# Password hashing cost
BCRYPT_ROUNDS=10

# Comma-separated allowed origins
# Local examples:
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Single-link Vercel production example:
# CORS_ORIGIN=https://your-project.vercel.app
# If you also use preview URLs, add them comma-separated.
CORS_ORIGIN=http://localhost:5173
