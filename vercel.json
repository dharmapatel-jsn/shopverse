{
  "version": 2,
  "installCommand": "npm ci --omit=dev --prefix backend && npm ci --include=dev --prefix client-side && npm ci --include=dev --prefix admin-side",
  "buildCommand": "npm run build",
  "routes": [
    {
      "src": "^/api(?:/(.*))?$",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "^/(?:client|admin)(?:/.*)?$",
      "dest": "/backend/api/index.js"
    },
    {
      "src": "^/$",
      "dest": "/backend/api/index.js"
    }
  ]
}
